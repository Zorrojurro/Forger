# Forger Backend Configuration
# Copy this file to .env and fill in your API keys

# Google Gemini API Keys (2 keys = double the rate limit!)
# Key 1: Used by Researcher + Writer agents
GOOGLE_API_KEY=your_gemini_api_key_here

# Key 2: Used by Editor + SEO agents (falls back to Key 1 if not set)
GOOGLE_API_KEY_2=your_second_gemini_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Content Generation Settings
DEFAULT_MODEL=gemini-2.0-flash
